# Copy this file to ".env" and change the key to a long random value.
# On Linux you can generate one with:  openssl rand -hex 24
COLLECTOR_API_KEY=change-me-to-a-long-random-string

# Address/port the service listens on. Keep it 127.0.0.1 so it is reachable
# ONLY from the same server (where Laravel runs). Do NOT use 0.0.0.0 in production.
COLLECTOR_HOST=127.0.0.1
COLLECTOR_PORT=8800
