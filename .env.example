APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/fttx/public
APP_TIMEZONE=Asia/Dhaka

# Local XAMPP/Laragon subdirectory example above.
#
# Production example (FTTX on port 81, document root = /var/www/app/fttx/public):
# APP_URL=http://auth.antbd.net:81
# APP_ENV=production
# APP_DEBUG=false
# SESSION_SECURE_COOKIE=false
# SESSION_COOKIE=fttx_noc_session
#
# Production HTTPS at domain root (document root = /public):
# APP_URL=https://your-domain.com
# TRUSTED_PROXIES=*
# SESSION_SECURE_COOKIE=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=fttx
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave empty/null unless you need a specific cookie domain (e.g. .example.com)
SESSION_DOMAIN=
# Production HTTPS only:
# SESSION_SECURE_COOKIE=true
# TRUSTED_PROXIES=*

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"


OLT_COLLECTOR_URL=http://127.0.0.1:8800
OLT_COLLECTOR_KEY=the-same-key-you-set-in-the-python-.env
